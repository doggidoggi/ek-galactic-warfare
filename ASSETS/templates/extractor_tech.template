[core]
autoTriggerCooldownTime: 1s
@memory prod1inc: boolean
@memory prod2inc: boolean
@memory prod3inc: boolean
updateUnitMemory: """
  prod1inc=true,
  prod2inc=true,
  prod3inc=true
"""

# [hiddenAction_boost1]
# autoTrigger: if self.globalTeamTags(includes='${tech_prod1}')
# addResourcesWithLogic: cash=${core.income*0.25}
