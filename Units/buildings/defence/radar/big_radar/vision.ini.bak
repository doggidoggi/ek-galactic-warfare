[core]
name:vision
class: CustomUnitMetadata
price:0
maxHp:1000
mass:3000
techLevel:1
buildSpeed:1
radius: 0
displayRadius: 0
isBuilding:true
numBitsOnDeath:8
isBio:false
isUnselectable:true
tags:vision
canOnlyBeAttackedByUnitsWithTags:alk
explodeOnDeath:true
isUnrepairableUnit:true
showInEditor: false
fogOfWarSightRange:35
disableDeathOnZeroHp:true
showOnMinimap:false

[graphics]
drawLayer:bottom
total_frames:1
scaleImagesTo:0
image:SHARED:blank.png
image_wreak:NONE
image_turret:SHARED:blank.png
showHealthBar:false
icon_zoomed_out:SHARED:blank.png

[attack]
canAttack:false
canAttackFlyingUnits: false
canAttackLandUnits:false
canAttackUnderwaterUnits:false
turretSize: 0
aimOffsetSpread: -0.01
turretTurnSpeed: 100
shootDelay:0
maxAttackRange:0

[movement]
movementType:NONE
moveSpeed: 0
moveAccelerationSpeed: 0.00001
moveDecelerationSpeed: 0.00001
maxTurnSpeed: 0
turnAcceleration: 0.00001
moveSlidingMode :false
moveIgnoringBody:false
targetHeight:0

[hiddenAction_die]
autoTrigger:if self.timeAlive(laterThanSeconds=8)
deleteSelf:true

[hiddenAction_created]
autoTriggerOnEvent:created
alsoQueueAction:setFlag

[hiddenAction_setFlag]
buildSpeed:0.5s
addResources:setFlag=1
addAllActionCooldownsFor:180s

[effect_detect]
life:240
fadeOut: true
fadeInTime:5
priority:critical
attachedToUnit:false
scaleFrom:5.1
scaleTo:5.1
dirOffsetRandom:180
alpha: 1.0
atmospheric:true
dirSpeed:0.25
showInFog:true
image:detect.png
drawUnderUnits:false
alsoPlaySound:detect.ogg:0.6