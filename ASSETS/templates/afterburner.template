[decal_afterburner]layer: beforeBody@global afterburnerScale: 1image: ROOT:shared/graphicsEffects/afterburner.pngonlyWhileAlive: truebasePosition: self.getOffsetRelative(dirOffset=rnd(-0.5,0.5))imageScaleY: (self.speed/1.1*${afterburnerScale})imageScaleX: (self.speed/2+0.3*${afterburnerScale})yOffsetRelative: -${core.radius+3}alpha: self.speed*rnd(0.7,1)[decal_afterburnerLight]layer: beforeUI image: SHARED:light_25.pngonlyWhileAlive: trueyOffsetRelative: -${core.radius+3}alpha: self.speed*rnd(0.5,1)imageScale: ${afterburnerScale}color: #ffff00[decal_afterburnerLight2]layer: beforeUIimage: SHARED:light_50.pngonlyWhileAlive: trueyOffsetRelative: -${core.radius+3}alpha: self.speed*rnd(0.5,1)/6imageScale: 2*${afterburnerScale}color: #ffff00[decal_afterburnerLight3]layer: beforeUIimage: ROOT:shared/graphicsEffects/sg_flare_short_8.pngonlyWhileAlive: trueyOffsetRelative: -${core.radius+3}alpha: self.speed*rnd(0.7,1)imageScale: 0.15*${afterburnerScale}alwayStartDirAtZero: true